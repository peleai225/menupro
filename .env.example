# ═══════════════════════════════════════════════════════════════════
# MenuPro — Configuration (copier en .env et remplir pour le déploiement)
# ═══════════════════════════════════════════════════════════════════

APP_NAME=MenuPro
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://votre-domaine.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

# Logs (production : single ou daily, level info ou warning)
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# ═══════════════════════════════════════════════════════════════════
# Base de données (MySQL recommandé en production)
# ═══════════════════════════════════════════════════════════════════
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=menupro
DB_USERNAME=
DB_PASSWORD=
# DB_URL=mysql://user:password@host:3306/menupro (alternative)
# DB_CHARSET=utf8mb4
# DB_COLLATION=utf8mb4_unicode_ci

# ═══════════════════════════════════════════════════════════════════
# Session (file ou database en production)
# ═══════════════════════════════════════════════════════════════════
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# SESSION_SECURE_COOKIE=true  # mettre true si HTTPS uniquement

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Cache (database ou redis en production)
CACHE_STORE=database
# CACHE_PREFIX=

# Memcached (si utilisé)
MEMCACHED_HOST=127.0.0.1

# Redis (optionnel, pour cache/queue)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ═══════════════════════════════════════════════════════════════════
# Mail (SMTP en production)
# ═══════════════════════════════════════════════════════════════════
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@votre-domaine.com"
MAIL_FROM_NAME="${APP_NAME}"

# ═══════════════════════════════════════════════════════════════════
# Stockage fichiers (S3 optionnel pour médias)
# ═══════════════════════════════════════════════════════════════════
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ═══════════════════════════════════════════════════════════════════
# Wave CI — Paiements commandes + Retraits restaurants (Pay-Out)
# Dashboard : https://dashboard.wave.com/developers/api
# ═══════════════════════════════════════════════════════════════════
WAVE_API_KEY=           # Clé API Wave (Bearer token pour les appels REST)
WAVE_SIGNING_SECRET=    # Secret de signature des webhooks (header Wave-Signature)
# WAVE_BASE_URL=https://api.wave.com/v1   # URL de base (optionnel, valeur par défaut dans config/wave.php)
# WAVE_COMMISSION_RATE=0.02               # Commission MenuPro sur paiements Wave (défaut 2%)

# ═══════════════════════════════════════════════════════════════════
# MenuPro — Commando (parrainage / agents)
# ═══════════════════════════════════════════════════════════════════
COMMANDO_MONTHLY_TARGET=10
# Commission (centimes) versée à l'agent au 1er paiement d'un restaurant parrainé (ex: 500000 = 5000 FCFA)
COMMANDO_COMMISSION_CENTS_FIRST_PAYMENT=500000
# true = une seule commission par restaurant (1er paiement uniquement)
COMMANDO_COMMISSION_ONLY_FIRST_PAYMENT=true

# ═══════════════════════════════════════════════════════════════════
# FusionPay (MoneyFusion) — Paiements + Transferts
# ═══════════════════════════════════════════════════════════════════
# FUSIONPAY_API_URL=  # URL API depuis Money Fusion > API de paiement
# FUSIONPAY_PRIVATE_KEY=  # Clé privée pour les retraits (pay-out)

# ═══════════════════════════════════════════════════════════════════
# MenuPro — Paiement Lygos (commandes clients, par restaurant)
# ═══════════════════════════════════════════════════════════════════
LYGOS_BASE_URL=https://api.lygosapp.com/v1
LYGOS_WEBHOOK_SECRET=

# ═══════════════════════════════════════════════════════════════════
# MenuPro — Paiement GeniusPay (abonnements restaurants)
# Clés configurées dans Admin > Paramètres > Paiements
# Base URL: https://pay.genius.ci/api/v1/merchant
# ═══════════════════════════════════════════════════════════════════
# GENIUSPAY_BASE_URL=https://pay.genius.ci/api/v1/merchant
# GENIUSPAY_WEBHOOK_SECRET=whsec_sandbox_xxx ou whsec_live_xxx
# GENIUSPAY_DIRECT_WAVE=true pour paiement push Wave (si le scan QR ne prélève pas)

# ═══════════════════════════════════════════════════════════════════
# MenuPro Hub — Paiement direct comptes marchands (Wave, Orange, MTN)
# Webhook SMS Gateway : POST /webhooks/menupo-hub/verify-payment
# ═══════════════════════════════════════════════════════════════════
# MENUPO_HUB_WEBHOOK_SECRET=secret-pour-signer-les-requetes-webhook

# ═══════════════════════════════════════════════════════════════════
# MenuPro — WhatsApp (Commando : bienvenue / carte agent)
# ═══════════════════════════════════════════════════════════════════
WHATSAPP_ENABLED=false
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_PHONE_ID=
